layout {
    tab name="dev" focus=true {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        pane split_direction="vertical" {
            pane size="75%" {
                pane command="nvim" focus=true size="80%"
                pane size="20%"
            }
            pane command="claude" size="25%"
        }
    }

    new_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        pane
    }
}
